  "homepage": "https://github.com/classytic/labs#readme",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/core.test.ts tests/catalog.test.ts tests/stage-templates.test.ts",
    "test:package": "vitest run tests/widgets.test.tsx",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "gallery": "npm run build && node tests/gallery/rasterize.mjs",
    "gallery:svg": "vitest run tests/gallery.test.tsx",
    "lint": "tsc --noEmit",
    "verify": "npm run typecheck && npm test",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "push": "classytic-push",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
